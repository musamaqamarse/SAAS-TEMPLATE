{
  "name": "create-saas",
  "version": "0.3.0",
  "description": "SaaS scaffolding engine: spin up backend + website + admin + mobile starters wired to Supabase or Firebase.",
  "type": "module",
  "bin": {
    "create-saas": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "create": "tsx src/index.ts",
    "doctor": "tsx src/index.ts doctor",
    "lint": "tsc -p tsconfig.lint.json",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@create-saas/core": "workspace:*",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.47.0",
    "posthog-node": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
