{
  "name": "create-saas",
  "version": "0.2.0",
  "private": true,
  "description": "SaaS scaffolding engine: spin up backend + website + admin + mobile starters wired to Supabase or Firebase.",
  "type": "module",
  "bin": {
    "create-saas": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "create": "tsx src/index.ts",
    "doctor": "tsx src/index.ts doctor",
    "lint": "tsc -p tsconfig.lint.json",
    "test": "vitest",
    "test:run": "vitest run",
    "validate:templates": "tsx scripts/validate-templates.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.47.0",
    "posthog-node": "^4.4.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
