{
  "name": "create-saas-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for create-saas: the headless engine, the CLI, and the web UI.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "build:all": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:run": "pnpm -r run test:run",
    "validate:templates": "tsx scripts/validate-templates.ts",
    "prerender:flutter": "tsx scripts/prerender-flutter.ts",
    "clean": "pnpm -r run clean",
    "dev": "pnpm --filter create-saas run dev",
    "doctor": "pnpm --filter create-saas run doctor",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@create-saas/core": "workspace:*",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
