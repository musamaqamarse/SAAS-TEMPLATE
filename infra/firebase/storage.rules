rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Per-user uploads under /<uid>/...
    match /{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
