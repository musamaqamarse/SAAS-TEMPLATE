# Firebase — this file is a placeholder only.
# Firebase config for Flutter is generated by `flutterfire configure`,
# which creates lib/firebase_options.dart automatically.
# Run that command, then uncomment the import + options line in lib/main.dart.
#
# Google Sign-In also requires:
#   Android: add SHA-1 fingerprint in Firebase Console → Project Settings → Android app
#   iOS: download updated GoogleService-Info.plist after enabling Sign-In with Google
