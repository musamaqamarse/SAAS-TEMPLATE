# Firebase — copy to .env.local and fill in your project values.
# Service account: Firebase Console → Project Settings → Service accounts → Generate new private key

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# Either set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON,
# or deploy in an environment with Application Default Credentials (Cloud Run, GCE, etc.)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
